// FAMILY LEDGER SCHEMA
// Keep new models grouped by domain so the relationship graph stays readable.
// Add friendship and group models under SOCIAL GRAPH AND FRIEND GROUPS.

// =============================================================================
// PRISMA CONFIGURATION
// =============================================================================

generator client {
  provider   = "prisma-client-js"
  output     = "../app/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// IDENTITY AND AUTHENTICATION
// =============================================================================

model User {
  id                         Int                    @id @default(autoincrement())
  email                      String                 @unique
  username                   String                 @unique
  passwordHash               String
  role                       UserRole               @default(USER)
  isActive                   Boolean                @default(true)
  showFriendsOnProfile       Boolean                @default(true)
  showFriendGroupsOnProfile  Boolean                @default(true)
  showFamiliesOnProfile      Boolean                @default(true)
  showFamilyFriendsOnProfile Boolean                @default(true)
  lastLogin                  DateTime?              @db.Timestamptz(3)
  createdAt                  DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt                  DateTime               @updatedAt @db.Timestamptz(3)
  deletedAt                  DateTime?              @db.Timestamptz(3)
  profileImageUrl            String?
  createdFamilies            Family[]               @relation("FamilyCreatedBy")
  receivedFamilyJoinRequests FamilyJoinRequest[]    @relation("FamilyJoinAddressee")
  sentFamilyJoinRequests     FamilyJoinRequest[]    @relation("FamilyJoinRequester")
  familyMembers              FamilyMember[]
  friendGroups               FriendGroup[]
  friendGroupMembers         FriendGroupMember[]
  oauthAccounts              OAuthAccount[]
  plaidItems                 PlaidItem[]
  sessions                   Session[]
  sharingProfiles            SharingProfile[]       @relation("SharingProfileOwner")
  sharingProfileTargets      SharingProfileTarget[] @relation("SharingProfileTargetUser")
  transactions               Transaction[]
  receivedFriendRequests     UserFriend[]           @relation("UserFriendAddressee")
  sentFriendRequests         UserFriend[]           @relation("UserFriendRequester")
  sharedTransactions         TransactionShare[]
}

model OAuthAccount {
  id                Int           @id @default(autoincrement())
  userId            Int
  provider          OAuthProvders
  providerAccountId String
  email             String
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  revokedAt DateTime? @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =============================================================================
// FAMILIES AND HOUSEHOLD MEMBERSHIP
// =============================================================================
// FamilyMember is the join table between Family and User.

model Family {
  id                           Int                    @id @default(autoincrement())
  name                         String
  createdBy                    Int
  createdAt                    DateTime               @default(now()) @db.Timestamptz(3)
  deletedAt                    DateTime?              @db.Timestamptz(3)
  creator                      User                   @relation("FamilyCreatedBy", fields: [createdBy], references: [id])
  members                      FamilyMember[]
  joinRequests                 FamilyJoinRequest[]
  transactions                 Transaction[]
  transactionCategories        TransactionCategory[]
  sentFamilyFriendRequests     FamilyFriend[]         @relation("FamilyFriendRequester")
  receivedFamilyFriendRequests FamilyFriend[]         @relation("FamilyFriendAddressee")
  sharingProfileTargets        SharingProfileTarget[]
  transactionShares            TransactionShare[]
}

model FamilyMember {
  id                Int              @id @default(autoincrement())
  familyId          Int
  userId            Int
  memberRole        FamilyMemberRole @default(MEMBER)
  relationshipLabel String?
  joinedAt          DateTime         @default(now()) @db.Timestamptz(3)
  isActive          Boolean          @default(true)
  leftAt            DateTime?        @db.Timestamptz(3)
  family            Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
}

// FamilyJoinRequest stores pending invitations before a user becomes an active
// FamilyMember. Keeping this separate from FamilyMember makes it clear that an
// invitation is not membership until the invited user accepts.
model FamilyJoinRequest {
  id          Int                     @id @default(autoincrement())
  familyId    Int
  requesterId Int
  addresseeId Int
  status      FamilyJoinRequestStatus @default(PENDING)
  createdAt   DateTime                @default(now()) @db.Timestamptz(3)
  acceptedAt  DateTime?               @db.Timestamptz(3)

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  requester User   @relation("FamilyJoinRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User   @relation("FamilyJoinAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([familyId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

// =============================================================================
// SOCIAL GRAPH AND FRIEND GROUPS
// =============================================================================
model UserFriend {
  id          Int          @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  acceptedAt  DateTime?    @db.Timestamptz(3)

  requester User @relation("UserFriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("UserFriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model FamilyFriend {
  id                Int          @id @default(autoincrement())
  requesterFamilyId Int
  addresseeFamilyId Int
  status            FriendStatus @default(PENDING)
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  acceptedAt        DateTime?    @db.Timestamptz(3)

  requesterFamily Family @relation("FamilyFriendRequester", fields: [requesterFamilyId], references: [id], onDelete: Cascade)
  addresseeFamily Family @relation("FamilyFriendAddressee", fields: [addresseeFamilyId], references: [id], onDelete: Cascade)

  @@unique([requesterFamilyId, addresseeFamilyId])
  @@index([addresseeFamilyId])
}

model FriendGroup {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members               FriendGroupMember[]
  sharingProfileTargets SharingProfileTarget[]
  transactionShares     TransactionShare[]
  transactions          Transaction[]

  @@index([ownerId])
}

model FriendGroupMember {
  id            Int      @id @default(autoincrement())
  friendGroupId Int
  userId        Int
  addedAt       DateTime @default(now()) @db.Timestamptz(3)

  friendGroup FriendGroup @relation(fields: [friendGroupId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([friendGroupId, userId])
  @@index([userId])
}

// =============================================================================
// BANKING CONNECTIONS
// =============================================================================

model PlaidItem {
  id                 Int            @id @default(autoincrement())
  userId             Int
  itemId             String         @unique
  accessToken        String
  transactionsCursor String?
  institutionId      String?
  institutionName    String?
  createdAt          DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime       @updatedAt @db.Timestamptz(3)
  accounts           PlaidAccount[]
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlaidAccount {
  id           Int           @id @default(autoincrement())
  plaidItemId  Int
  accountId    String        @unique
  name         String
  officialName String?
  mask         String?
  type         String?
  subtype      String?
  item         PlaidItem     @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([plaidItemId])
}

// =============================================================================
// LEDGER TRANSACTIONS AND CATEGORIES
// =============================================================================

model Transaction {
  id                 Int                   @id @default(autoincrement())
  familyId           Int?
  friendGroupId      Int?
  sharingProfileId   Int?
  categoryId         Int?
  createdByUserId    Int
  visibility         TransactionVisibility @default(PERSONAL)
  amountCents        Int
  type               TransactionType
  merchant           String?
  note               String?
  occurredAt         DateTime              @default(now()) @db.Timestamptz(3)
  createdAt          DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @db.Timestamptz(3)
  deletedAt          DateTime?             @db.Timestamptz(3)
  plaidAccountId     Int?
  plaidTransactionId String?               @unique
  category           TransactionCategory?  @relation(fields: [categoryId], references: [id])
  createdBy          User                  @relation(fields: [createdByUserId], references: [id])
  family             Family?               @relation(fields: [familyId], references: [id])
  friendGroup        FriendGroup?          @relation(fields: [friendGroupId], references: [id])
  plaidAccount       PlaidAccount?         @relation(fields: [plaidAccountId], references: [id])
  sharingProfile     SharingProfile?       @relation(fields: [sharingProfileId], references: [id])
  shares             TransactionShare[]

  @@index([familyId, occurredAt, createdByUserId, categoryId])
  @@index([friendGroupId])
  @@index([sharingProfileId])
}

model TransactionShare {
  id            Int             @id @default(autoincrement())
  transactionId Int
  targetType    ShareTargetType
  userId        Int?
  familyId      Int?
  friendGroupId Int?
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  family        Family?         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  friendGroup   FriendGroup?    @relation(fields: [friendGroupId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([friendGroupId])
  @@index([userId])
}

model SharingProfile {
  id           Int                    @id @default(autoincrement())
  userId       Int
  name         String
  resourceType SharingResourceType    @default(TRANSACTION)
  isDefault    Boolean                @default(false)
  createdAt    DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime               @updatedAt @db.Timestamptz(3)
  user         User                   @relation("SharingProfileOwner", fields: [userId], references: [id], onDelete: Cascade)
  targets      SharingProfileTarget[]
  transactions Transaction[]

  @@unique([userId, resourceType, name])
  @@index([userId, resourceType, isDefault])
}

model SharingProfileTarget {
  id               Int             @id @default(autoincrement())
  sharingProfileId Int
  targetType       ShareTargetType
  userId           Int?
  familyId         Int?
  friendGroupId    Int?
  sharingProfile   SharingProfile  @relation(fields: [sharingProfileId], references: [id], onDelete: Cascade)
  user             User?           @relation("SharingProfileTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  family           Family?         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  friendGroup      FriendGroup?    @relation(fields: [friendGroupId], references: [id], onDelete: Cascade)

  @@index([sharingProfileId])
  @@index([familyId])
  @@index([friendGroupId])
  @@index([userId])
}

model TransactionCategory {
  id           Int           @id @default(autoincrement())
  familyId     Int
  name         String
  type         CategoryType  @default(EXPENSE)
  isArchived   Boolean       @default(false)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  transactions Transaction[]
  family       Family        @relation(fields: [familyId], references: [id])

  @@unique([familyId, name])
  @@index([familyId])
}

// =============================================================================
// SHARED ENUMS
// =============================================================================

enum UserRole {
  USER
  ADMIN
  STAFF
}

enum FamilyMemberRole {
  OWNER
  CO_OWNER
  MEMBER
}

enum OAuthProvders {
  GOOGLE
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum TransactionVisibility {
  PERSONAL
  FAMILY
  FRIEND_GROUP
  SPECIFIC_USERS
  CUSTOM
}

enum SharingResourceType {
  TRANSACTION
  RECIPE
  ALL
}

enum ShareTargetType {
  FAMILY
  FRIEND_GROUP
  USER
}

enum CategoryType {
  EXPENSE
  INCOME
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum FamilyJoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}
